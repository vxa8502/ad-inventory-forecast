# Git and version control
.git
.gitignore

# Environment and credentials
.env
.env.*
*.json
credentials/

# Python bytecode
*.pyc
__pycache__/
*.pyo
.pytest_cache/
*.egg-info/

# Development directories (not needed in container)
home/
scripts/
sql/
data/
docs/
.devcontainer/

# Vertex AI pipeline code (separate from Cloud Run dashboard build)
# pipelines/ contains Kubeflow DAG definitions compiled separately via kfp.v2.compiler
# and uploaded to Cloud Storage for Cloud Scheduler triggers
# Note: pipelines/*.yaml (compiler output) is excluded by this directory exclusion
pipelines/

# Note: tests/ and src/ are intentionally NOT excluded (Cloud Build CI needs them)

# Documentation (except README)
*.md
!README.md

# IDE and editor files
.vscode/
.idea/
*.swp
*.swo

# Virtual environments
.venv/
venv/
